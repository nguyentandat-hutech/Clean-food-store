# ================================================================
# .env — Biến môi trường cho Docker Compose
# Sao chép file này → .env và điền giá trị thực
# KHÔNG commit file .env lên Git
# ================================================================

# ── MongoDB (tài khoản root trong container) ─────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=changeme_strong_password

# ── Node.js backend ──────────────────────────────────────────
NODE_ENV=production
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING
JWT_EXPIRES_IN=7d

# ── CORS — URL mà frontend được phép gọi API ─────────────────
CLIENT_URL=http://localhost:3000

# ── Email (Nodemailer / Gmail App Password) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=nguyennhatquang522004@gmail.com
SMTP_PASS=ffuxnpjvlmtkmsil
MAIL_FROM="Clean Food Store <noreply@cleanfood.vn>"

# ── VNPay (sandbox) ──────────────────────────────────────────
VNP_TMN_CODE=8BLUV6U8
VNP_HASH_SECRET=YMNEKS3I6380ABEHK6KA9FMWG8S9GMFC
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:3000/order-success
# IPN URL: VNPay gọi về backend để xác nhận thanh toán
# Khi deploy production, thay localhost bằng domain/IP thực
VNP_IPN_URL=http://localhost:5000/api/orders/vnpay-ipn

# ── Frontend build ────────────────────────────────────────────
# VITE_ prefix để Vite nhúng giá trị vào bundle (nếu dùng axios base URL)
VITE_API_URL=http://localhost:5000
