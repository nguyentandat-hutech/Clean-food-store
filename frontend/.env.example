# ================================================================
# .env.example - Sao chép thành .env và điền giá trị thực
# Với Vite: biến môi trường BẮT BUỘC có prefix VITE_
# ================================================================

# URL gốc của Backend API
# Khi dùng Vite proxy (vite.config.js), để trống để dùng /api
VITE_API_BASE_URL=/api

# (Tùy chọn) Nếu deploy riêng backend:
# VITE_API_BASE_URL=https://your-backend.com/api
