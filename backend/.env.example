# ================================================================
# .env.example - Sao chép file này thành .env và điền giá trị thực
# KHÔNG commit file .env lên Git (đã có trong .gitignore)
# ================================================================

# --- Cấu hình Server ---
NODE_ENV=development
PORT=5000

# --- Database ---
# MongoDB Atlas URI (thay <username>, <password>, <cluster>, <dbname>)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# --- Bảo mật (JWT) ---
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING
JWT_EXPIRES_IN=7d

# --- CORS - URL của Frontend ---
CLIENT_URL=http://localhost:3000

# --- Cấu hình Email (Nodemailer) ---
# Dùng Gmail App Password hoặc Mailtrap để test
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=nguyennhatquang522004@gmail.com
SMTP_PASS=ffuxnpjvlmtkmsil
MAIL_FROM="Clean Food Store" <noreply@cleanfood.vn>

# --- VNPay (Thanh toán trực tuyến) ---
