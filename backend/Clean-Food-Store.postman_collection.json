{
  "info": {
    "name": "🥬 Clean Food Store API — Full Test Suite",
    "description": "Bộ test 100% API endpoints cho dự án Clean Food Store.\n\n## Hướng dẫn sử dụng\n1. Import file này vào Postman\n2. Chạy **01. Register** rồi **02. Login** để tự động lưu token\n3. Chạy lần lượt theo thứ tự folder để tạo dữ liệu phụ thuộc\n4. Các biến `{{farmId}}`, `{{categoryId}}`, `{{productId}}` ... được tự động set từ response\n\n## Authentication\n- Bearer Token tự động lưu vào biến `{{token}}` sau khi Login\n- Tất cả request protected sẽ dùng `{{token}}` từ collection variables",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "farmId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "batchId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "reviewId", "value": "" },
    { "key": "discountId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "🏥 Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] },
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Server is running', function () {",
                "    pm.response.to.have.status(200);",
                "    pm.expect(pm.response.json().success).to.be.true;",
                "});"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "01. Register (User)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nguyễn Văn Test\",\n  \"email\": \"testuser@cleanfood.vn\",\n  \"password\": \"Test@123456\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Register success', function () {",
                "    pm.response.to.have.status(201);",
                "    const json = pm.response.json();",
                "    pm.expect(json.success).to.be.true;",
                "    if (json.data && json.data.token) {",
                "        pm.collectionVariables.set('token', json.data.token);",
                "    }",
                "    if (json.data && json.data.user && json.data.user._id) {",
                "        pm.collectionVariables.set('userId', json.data.user._id);",
                "    }",
                "});"
              ]
            }
          }]
        },
        {
          "name": "02. Register (Admin — manual role set in DB)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin CleanFood\",\n  \"email\": \"admin@cleanfood.vn\",\n  \"password\": \"Admin@123456\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "03. Login (User)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@cleanfood.vn\",\n  \"password\": \"Test@123456\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Login success', function () {",
                "    pm.response.to.have.status(200);",
                "    const json = pm.response.json();",
                "    pm.expect(json.success).to.be.true;",
                "    if (json.data && json.data.token) {",
                "        pm.collectionVariables.set('token', json.data.token);",
                "    }",
                "    if (json.data && json.data.user && json.data.user._id) {",
                "        pm.collectionVariables.set('userId', json.data.user._id);",
                "    }",
                "});"
              ]
            }
          }]
        },
        {
          "name": "04. Login (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@cleanfood.vn\",\n  \"password\": \"Admin@123456\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Admin Login success', function () {",
                "    pm.response.to.have.status(200);",
                "    const json = pm.response.json();",
                "    if (json.data && json.data.token) {",
                "        pm.collectionVariables.set('token', json.data.token);",
                "        pm.collectionVariables.set('adminToken', json.data.token);",
                "    }",
                "});"
              ]
            }
          }]
        },
        {
          "name": "05. Get Me (Protected)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Get Me success', function () {",
                "    pm.response.to.have.status(200);",
                "    pm.expect(pm.response.json().data.user).to.have.property('email');",
                "});"
              ]
            }
          }]
        },
        {
          "name": "06. Login — Wrong Password (Negative)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@cleanfood.vn\",\n  \"password\": \"wrongpassword\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Login fails with wrong password', function () {",
                "    pm.response.to.have.status(401);",
                "});"
              ]
            }
          }]
        },
        {
          "name": "07. Get Me — No Token (Negative)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] },
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Unauthorized without token', function () {",
                "    pm.response.to.have.status(401);",
                "});"
              ]
            }
          }]
        }
      ]
    },
